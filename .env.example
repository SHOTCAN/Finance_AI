# Personal Finance AI — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit the .env file to git!

# --- App ---
DEBUG=false
PORT=8000

# --- Database (Railway PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@YOUR_HOST:5432/railway
DATABASE_URL_SYNC=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/railway

# --- Auth ---
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_64_CHARS
MAX_USERS=2

# --- Telegram ---
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
ADMIN_TELEGRAM_ID=YOUR_TELEGRAM_CHAT_ID

# --- Groq API (5 keys for rotation) ---
GROQ_API_KEY_1=gsk_xxx1
GROQ_API_KEY_2=gsk_xxx2
GROQ_API_KEY_3=gsk_xxx3
GROQ_API_KEY_4=gsk_xxx4
GROQ_API_KEY_5=gsk_xxx5

# --- Google Cloud ---
GOOGLE_SERVICE_ACCOUNT_FILE=ai-keuangan-488515-f0b54598d94a.json
GOOGLE_SHEETS_ENABLED=true
GOOGLE_VISION_ENABLED=true

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
